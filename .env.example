# העתק לקובץ .env ומלא ערכים (לעולם אל תעלה .env לגיטהאב)

# PostgreSQL (Neon / וכו׳) — מומלץ connection string של pooler, sslmode=require, בלי channel_binding
DATABASE_URL="postgresql://USER:PASSWORD@HOST/dbname?sslmode=require"

# כתובת האתר לקנוניקל ול־Open Graph
# מקומי:
NEXT_PUBLIC_SITE_URL="http://localhost:3000"
# Netlify (אחרי דיפלוי — Domain settings או כתובת netlify.app):
# NEXT_PUBLIC_SITE_URL="https://your-site.netlify.app"
