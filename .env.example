# העתק לקובץ .env ומלא ערכים (לעולם אל תעלה .env לגיטהאב)

# PostgreSQL (Neon) — שני מחרוזות מהדשבורד:
# 1) Pooled / Transaction — לאפליקציה (לרוב hostname עם ‎-pooler‎)
DATABASE_URL="postgresql://USER:PASSWORD@ep-xxx-pooler.region.aws.neon.tech/neondb?sslmode=require"
# 2) Direct — למיגרציות בלבד (hostname בלי ‎-pooler‎). בלי זה Netlify עלול להיכשל ב־P1002 / advisory lock
DIRECT_URL="postgresql://USER:PASSWORD@ep-xxx.region.aws.neon.tech/neondb?sslmode=require"

# כתובת האתר לקנוניקל ול־Open Graph
# מקומי:
NEXT_PUBLIC_SITE_URL="http://localhost:3000"
# Netlify (אחרי דיפלוי — Domain settings או כתובת netlify.app):
# NEXT_PUBLIC_SITE_URL="https://your-site.netlify.app"

# --- מסד נתונים (חובה פעם אחת אחרי clone / DB חדש) ---
# npx prisma migrate deploy
# npx prisma db seed
#
# טבלאות תוכן ובלוג (אחרי מיגרציות): content_category, content_page, blog_post,
# site_nav_link (הדר+פוטר), site_setting (טקסט הצהרה בפוטר).
# בדיקה: GET /api/health/db — אמור להחזיר contentPageCount > 0 אחרי seed.
#
# טקסטים גלובליים (דף הבית, כותרות הדר/פוטר) בטבלת site_setting — עריכה ב-Prisma Studio או עדכון seed.
