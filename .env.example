# העתק לקובץ .env ומלא ערכים (לעולם אל תעלה .env לגיטהאב)

# PostgreSQL (Neon / וכו׳) — מומלץ connection string של pooler, sslmode=require, בלי channel_binding
DATABASE_URL="postgresql://USER:PASSWORD@HOST/dbname?sslmode=require"

# כתובת האתר לקנוניקל ול־Open Graph (בפרודקשן: הדומיין המלא)
NEXT_PUBLIC_SITE_URL="http://localhost:3000"
