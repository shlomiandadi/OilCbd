generator client {
  provider      = "prisma-client-js"
  /// native = מקומי; debian/rhel = תמונות Netlify שונות — שני היעדים מכסים שגיאות query engine
  binaryTargets = ["native", "debian-openssl-3.0.x", "rhel-openssl-3.0.x"]
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

/// מוצר לוגי (שם + תיאור); הוריאציות הנפרדות למכירה ב־ProductVariant
model Product {
  id               String            @id @default(cuid())
  name             String
  description      String            @db.Text
  isActive         Boolean           @default(true)
  /// מזהה יחיד לכתובת /products/[slug]
  slug             String            @unique
  /// כותרת SEO (מטא title) לגוגל
  seoTitle         String
  /// מטא תיאור לתוצאות חיפוש (עד ~155 תווים)
  seoDescription   String            @db.Text
  /// מילות מפתח מופרדות בפסיקים (אופציונלי)
  seoKeywords      String?
  /// נתיב קנוני יחסי, למשל /products/full-spectrum — ישולב עם NEXT_PUBLIC_SITE_URL
  canonicalPath    String
  /// תמונת Open Graph (אופציונלי; אם ריק — נשתמש בתמונת וריאציה ראשונה)
  ogImage          String?
  /// פירורי לחם: [{ "name": "...", "href": "/..." }]
  breadcrumbJson   Json
  createdAt        DateTime          @default(now())
  updatedAt        DateTime          @updatedAt
  variants         ProductVariant[]

  @@index([slug])
}

/// וריאציה למכירה (נפח, ריכוז, מחיר, מלאי)
model ProductVariant {
  id             String      @id @default(cuid())
  productId      String
  label          String
  price          Float
  image          String
  cbdPercentage  Float
  thcPercentage  Float?
  volumeMl       Int
  stock          Int         @default(0)
  labResultsUrl  String?
  isActive       Boolean     @default(true)
  sortOrder      Int         @default(0)
  product        Product     @relation(fields: [productId], references: [id], onDelete: Cascade)
  orderItems     OrderItem[]

  @@index([productId])
}

model Order {
  id              String      @id @default(cuid())
  customerName    String
  customerEmail   String
  customerPhone   String
  shippingAddress String      @db.Text
  totalAmount     Float
  status          String      @default("PENDING")
  paymentMethod   String
  paymentId       String?
  referenceNumber String?
  items           OrderItem[]
  createdAt       DateTime    @default(now())
  updatedAt       DateTime    @updatedAt
}

model OrderItem {
  id               String         @id @default(cuid())
  orderId          String
  productVariantId String
  quantity         Int
  priceAtBuy       Float
  order            Order          @relation(fields: [orderId], references: [id], onDelete: Cascade)
  productVariant   ProductVariant @relation(fields: [productVariantId], references: [id])

  @@index([orderId])
  @@index([productVariantId])
}

/// קטגוריות למדריכים ובלוג
model ContentCategory {
  id             String        @id @default(cuid())
  slug           String        @unique
  name           String
  description    String?       @db.Text
  seoTitle       String?
  seoDescription String?       @db.Text
  sortOrder      Int           @default(0)
  pages          ContentPage[]
  posts          BlogPost[]

  @@index([slug])
  @@map("content_category")
}

/// עמודי תוכן סמכותיים (מילות מפתח / זנב ארוך) — נמשכים מהמסד
model ContentPage {
  id                String           @id @default(cuid())
  slug              String           @unique
  categoryId        String?
  category          ContentCategory? @relation(fields: [categoryId], references: [id], onDelete: SetNull)
  title             String
  excerpt           String?          @db.Text
  bodyMarkdown      String           @db.Text
  seoTitle          String
  seoDescription    String           @db.Text
  seoKeywords       String?
  canonicalPath     String
  ogImage           String?
  breadcrumbJson    Json
  /// ביטויי זנב ארוך לטמיעה (מערך מחרוזות)
  targetPhrasesJson Json?
  /// שאלות ותשובות ל־JSON-LD FAQPage — [{ "question": "...", "answer": "..." }]
  faqJson           Json?
  /// האם להציג ברשימת /learn (עמודי about/contact — false)
  showInLearnIndex Boolean         @default(true)
  isPublished       Boolean          @default(true)
  createdAt         DateTime         @default(now())
  updatedAt         DateTime         @updatedAt

  @@index([categoryId])
  @@index([slug])
  @@map("content_page")
}

/// מאמרי בלוג
model BlogPost {
  id             String           @id @default(cuid())
  slug           String           @unique
  categoryId     String?
  category       ContentCategory? @relation(fields: [categoryId], references: [id], onDelete: SetNull)
  title          String
  excerpt        String?          @db.Text
  bodyMarkdown   String           @db.Text
  coverImage     String?
  seoTitle       String
  seoDescription String           @db.Text
  seoKeywords    String?
  canonicalPath  String
  ogImage        String?
  breadcrumbJson Json
  isPublished    Boolean          @default(true)
  publishedAt    DateTime?
  createdAt      DateTime         @default(now())
  updatedAt      DateTime         @updatedAt

  @@index([categoryId])
  @@index([slug])
  @@map("blog_post")
}

/// קישורי הדר / פוטר (SEO — טקסט עוגן ברור)
model SiteNavLink {
  id        String        @id @default(cuid())
  label     String
  href      String
  section   String
  sortOrder Int           @default(0)
  parentId  String?
  parent    SiteNavLink?  @relation("NavTree", fields: [parentId], references: [id], onDelete: Cascade)
  children  SiteNavLink[] @relation("NavTree")

  @@index([section])
  @@index([parentId])
  @@map("site_nav_link")
}

/// טקסטים גלובליים (פוטר משפטי וכו׳)
model SiteSetting {
  key   String @id
  value String @db.Text

  @@map("site_setting")
}
